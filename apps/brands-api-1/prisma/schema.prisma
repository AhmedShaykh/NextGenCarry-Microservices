generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Gucci {
  id        String   @id @default(cuid())
  title     String
  desc      String
  imageUrl  String   @unique
  category  Category
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Rolex {
  id        String   @id @default(cuid())
  title     String
  desc      String
  imageUrl  String   @unique
  category  Category
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Category {
  LUXURY_HANDBAGS
  SHOES_HEELS
  JEWELRY
  CLOTHING
  PURSE
  WATCHES
  BELTS
  SUNGLASSES
  SUITCASE
  JACKETS
}
